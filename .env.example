# File: .env.example
# Purpose: Copy this to .env and fill in your values

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fastapi_db
JWT_SECRET_KEY=super-secret-key-change-in-production-min32chars
JWT_REFRESH_SECRET_KEY=super-refresh-key-change-in-production-min32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
BCRYPT_ROUNDS=12
